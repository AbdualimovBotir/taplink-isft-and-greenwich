  "steps": {
    "title": {
      "uz": "Dual Degree — Qadamma-qadam",
      "ru": "Dual Degree — Шаг за шагом",
      "en": "Dual Degree — Step by Step"
    },
    "items": [
      {
        "num": "01",
        "title": {
          "uz": "Ro'yxatdan o'ting",
          "ru": "Зарегистрируйтесь",
          "en": "Register"
        },
        "desc": {
          "uz": "ISFT Samarqand filialiga onlayn ariza topshiring. GEMS qabul mezonlarini belgilaydi va barcha rasmiy takliflarni tasdiqlaydi.",
          "ru": "Подайте онлайн-заявку в филиал ISFT Самарканд. GEMS определяет критерии приёма и утверждает все официальные предложения.",
          "en": "Submit an online application to ISFT Samarkand branch. GEMS sets admission criteria and approves all official offers."
        }
      },
      {
        "num": "02",
        "title": {
          "uz": "Samarqandda tahsil oling",
          "ru": "Учитесь в Самарканде",
          "en": "Study in Samarkand"
        },
        "desc": {
          "uz": "Barcha ta'lim ISFT kampusida — o'z shahringizda. GEMS o'qituvchilari va Britaniya professorlari bevosita dars beradi.",
          "ru": "Всё обучение проходит в кампусе ISFT — в вашем городе. Преподаватели GEMS и британские профессора ведут занятия напрямую.",
          "en": "All education is at ISFT campus — in your own city. GEMS teachers and British professors teach directly."
        }
      },
      {
        "num": "03",
        "title": {
          "uz": "Xalqaro standartda bilim",
          "ru": "Знания мирового уровня",
          "en": "International standard knowledge"
        },
        "desc": {
          "uz": "O'quv dasturlari University of Greenwich xalqaro standartlari asosida. Baholash va attestatsiya GEMS tomonidan amalga oshiriladi.",
          "ru": "Учебные программы основаны на международных стандартах Университета Гринвич. Оценка и аттестация проводятся GEMS.",
          "en": "Curricula based on University of Greenwich international standards. Assessment and attestation carried out by GEMS."
        }
      },
      {
        "num": "04",
        "title": {
          "uz": "Ikki diplom qo'lga kiriting",
          "ru": "Получите два диплома",
          "en": "Receive two degrees"
        },
        "desc": {
          "uz": "Bitirganingizda ISFT diplomi (O'zbekiston) va University of Greenwich diplomi (Buyuk Britaniya) beriladi — ikkisi ham rasmiy tan olinadi.",
          "ru": "По окончании выдаётся диплом ISFT (Узбекистан) и диплом Университета Гринвич (Великобритания) — оба официально признаны.",
          "en": "Upon graduation, an ISFT diploma (Uzbekistan) and University of Greenwich diploma (UK) are awarded — both officially recognized."
        }
      }
